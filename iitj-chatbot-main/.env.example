# ── LLM Provider ─────────────────────────────────────────────────
# Groq API (recommended — free tier, fast responses)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Fine-tuned local model toggle (requires trained model in models/finetuned_iitj/)
USE_FINETUNED_MODEL=false

# ── Retrieval ─────────────────────────────────────────────────────
TOP_K_NODES=8            # Number of knowledge-base nodes sent to LLM
MAX_TEXT_PER_NODE=800    # Max characters per node in LLM context
INDEX_FILE=../data/processed/iitj_index.json

# ── Answer Formatting ─────────────────────────────────────────────
ENABLE_ANSWER_FORMATTING=true   # Set false to return raw LLM output
MAX_RESPONSE_LENGTH=2000        # Max characters in formatted response

# ── Response Enhancement ──────────────────────────────────────────
ENABLE_SUGGESTIONS=true   # Show related follow-up question suggestions
ENABLE_FOOTER=true        # Append source citations + confidence badge
MAX_SUGGESTIONS=3         # Max follow-up suggestions per response

# ── Caching ───────────────────────────────────────────────────────
CACHE_MAX_SIZE=100        # Max cached query responses (in-memory LRU)

# ── Background Scraper ────────────────────────────────────────────
SCRAPER_ENABLED=true
SCRAPER_INTERVAL_HOURS=2
SCRAPER_MAX_PAGES=1500
TARGET_URL=https://www.iitjammu.ac.in
CRAWL_DELAY=1.2
JS_WAIT_MS=2000
MAX_CRAWL_PAGES=1500

# ── Server ────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=30

# ── CORS ──────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# For production:
# CORS_ORIGINS=https://www.iitjammu.ac.in,https://iitjammu.ac.in
