# This directory stores the LoRA fine-tuned adapter for the IIT Jammu model.
# Generated by running: python train_supervised.py
# Expected files after fine-tuning:
#   adapter_config.json
#   adapter_model.bin  (or adapter_model.safetensors)
#   pytorch_model.json  (training metadata)
#   tokenizer_config.json
#   tokenizer.json
